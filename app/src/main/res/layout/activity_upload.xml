<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF8F6"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_back_arrow"
                android:contentDescription="Back"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unggah Resep"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginStart="16dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <FrameLayout
                android:id="@+id/btnUploadVideo"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_dashed_border">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unggah Video"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:drawableTop="@drawable/ic_video_placeholder"
                    android:layout_marginTop="5dp" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/btnUploadFoto"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_dashed_border">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unggah Foto"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:drawableTop="@drawable/ic_photo_placeholder"
                    android:layout_marginTop="5dp" />
            </FrameLayout>
        </LinearLayout>

        <EditText android:id="@+id/etNamaMasakan" android:hint="Nama masakan" android:layout_width="match_parent" android:layout_height="50dp" android:paddingHorizontal="12dp" android:background="@drawable/bg_rounded_field" android:layout_marginBottom="15dp"/>

        <Spinner
            android:id="@+id/spinnerKategori"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_rounded_field"
            android:layout_marginBottom="15dp" />

        <EditText android:id="@+id/etAlatBahan" android:hint="Alat &amp; Bahan" android:layout_width="match_parent" android:layout_height="100dp" android:gravity="top" android:padding="12dp" android:background="@drawable/bg_rounded_field" android:layout_marginBottom="15dp"/>

        <EditText android:id="@+id/etLangkah" android:hint="Langkah Pembuatan" android:layout_width="match_parent" android:layout_height="120dp" android:gravity="top" android:padding="12dp" android:background="@drawable/bg_rounded_field" android:layout_marginBottom="20dp"/>

        <Button android:id="@+id/btnSubmit" android:text="Unggah Resep Sekarang" android:layout_width="match_parent" android:layout_height="wrap_content" android:backgroundTint="#B34D4D" android:textColor="@android:color/white"/>

    </LinearLayout>
</ScrollView>