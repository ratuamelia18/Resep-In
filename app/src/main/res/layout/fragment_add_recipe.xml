<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tambah Resep &amp; Video Lokal"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/edtTitle"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Nama Makanan (Contoh: Sate Ayam)"
            android:inputType="text"
            android:layout_marginBottom="16dp"
            android:paddingHorizontal="12dp"
            android:background="@android:drawable/edit_text"/>

        <Button
            android:id="@+id/btnPilihVideo"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="PILIH VIDEO DARI GALERI"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/txtVideoPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Belum ada video yang dipilih"
            android:textColor="#757575"
            android:textSize="14sp"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/edtDescription"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:hint="Format Pengisian:\nBahan:\n• Bahan 1\n• Bahan 2\n\nCara Membuat:\n1. Langkah 1"
            android:inputType="textMultiLine"
            android:gravity="top|start"
            android:layout_marginBottom="24dp"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"/>

        <Button
            android:id="@+id/btnSimpan"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="SIMPAN RESEP"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>
    </LinearLayout>
</ScrollView>